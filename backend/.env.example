# Django Production Settings
SECRET_KEY=your_super_secret_key_here
DEBUG=True

# Database Credentials (if applicable, uncomment and configure for postgres/mysql)
# DATABASE_URL=postgres://user:password@hostname:port/db_name

# Email (OTP). For real delivery to e.g. somaiya.edu:
# Use a Gmail (or other SMTP) account with an App Password: https://support.google.com/accounts/answer/185833
# OTP sends are synchronous: if SMTP fails, the API returns 503 and the server log shows the real error.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# For port 465 SSL instead: EMAIL_PORT=465 EMAIL_USE_TLS=False EMAIL_USE_SSL=True
EMAIL_TIMEOUT=30
EMAIL_HOST_USER=your_sender@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password
# DEFAULT_FROM_EMAIL=Apn-E-Dukaan <your_sender@gmail.com>

# With DEBUG=True: if USER+PASSWORD are set, SMTP is used automatically. If omitted, OTP goes to console only.
# USE_SMTP_EMAIL=false   # force console backend even when credentials exist
# EXPOSE_OTP_IN_API=true # include OTP in API JSON + toast (local debugging only; never in production)
